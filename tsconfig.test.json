{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "types": ["node"],
    "declaration": false,
    "incremental": false
  },
  "include": ["lib/**/*.ts", "tests/**/*.ts", "types/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
