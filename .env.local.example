# Optional: EIA API key for live Brent crude price data
# Get yours free at: https://www.eia.gov/opendata/register.php
# If omitted, the app uses the bundled historical fallback data (1960–2024)
NEXT_PUBLIC_EIA_API_KEY=

# Admin panel credentials (required for /admin routes)
# ADMIN_PASSWORD: the password you'll use to log in at /admin/login
# ADMIN_SECRET: a long random string used to sign the session cookie
#   Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD=change-me
ADMIN_SECRET=replace-with-a-long-random-string-at-least-32-chars
